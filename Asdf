<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PoGo Helper</title>
</head>
<body style="font-family: Arial; padding:20px;">

<h2>📍 PoGo Helper</h2>

<button onclick="getLocation()">取得位置</button>
<p id="loc">尚未定位</p>

<h3>🔢 IV 計算</h3>
<input id="cp" placeholder="CP"><br><br>
<input id="hp" placeholder="HP"><br><br>
<button onclick="calcIV()">計算 IV</button>

<p id="iv"></p>

<script>
function getLocation() {
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById("loc").innerText =
      pos.coords.latitude + "," + pos.coords.longitude;
  });
}

function calcIV() {
  let cp = Number(document.getElementById("cp").value);
  let hp = Number(document.getElementById("hp").value);
  if (!cp || !hp) return;

  let iv = Math.min(100, Math.round((hp / cp) * 120));
  document.getElementById("iv").innerText = "IV: " + iv + "%";
}
</script>

</body>
</html>
